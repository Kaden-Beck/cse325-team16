{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dotnet: build",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "build",
                "VehicleRentalManager/VehicleRentalManager.csproj"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "dotnet: run",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "run",
                "--project",
                "VehicleRentalManager/VehicleRentalManager.csproj"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "isBackground": false
        },
        {
            "label": "dotnet: clean",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "clean",
                "VehicleRentalManager/VehicleRentalManager.csproj"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always"
            }
        }
    ]
}

