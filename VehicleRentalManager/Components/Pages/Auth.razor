@page "/auth"
@inject NavigationManager Navigation
@inject AuthService AuthService

<h3>Authentication</h3>

@if (isLoading)
{
    <p>Loading authentication status...</p>
}
else if (currentUser?.IsAuthenticated == true)
{
    <p>
        You are signed in as @currentUser.Name (@currentUser.Email).
    </p>

    <button class="btn btn-secondary" @onclick="Logout">
        Sign out
    </button>
}
else
{
    <p>
        Sign in or create an account using your Google account.
    </p>

    <button class="btn btn-primary" @onclick="SignInWithGoogle">
        Sign In with Google
    </button>
}

@code {
    private AuthService.CurrentUserDto? currentUser;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // 1) Check if we are coming back from Google with a token in the URL
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var token = query["token"];

        if (!string.IsNullOrEmpty(token))
        {
            // 2) Store the JWT and configure HttpClient to use it
            await AuthService.StoreTokenAsync(token);

            // Optional: clear query string from the address bar
            Navigation.NavigateTo("/auth", forceLoad: false);
        }

        // 3) Load the current user from the auth service
        currentUser = await AuthService.GetCurrentUserAsync();
        isLoading = false;
    }

    private void SignInWithGoogle()
    {
        // After login/registration, the backend will redirect back to /auth
        var returnUrl = Uri.EscapeDataString("/auth");
        Navigation.NavigateTo($"/auth/login-google?returnUrl={returnUrl}", forceLoad: true);
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/auth", forceLoad: true);
    }
}
